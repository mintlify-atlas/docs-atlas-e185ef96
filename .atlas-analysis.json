  "keyFeatures": [
    "Supports Peppol SMP 1.x, OASIS BDXR SMP 1.0, and OASIS BDXR SMP 2.0 specifications",
    "CEF eDelivery compliant (first SMP to achieve this certification)",
    "Three pluggable storage backends: XML (file-based), SQL (MySQL/PostgreSQL/Oracle/DB2), and MongoDB",
    "Built-in management GUI for administering service groups, endpoints, and business cards",
    "Docker support with pre-built images for all three backends",
    "SML (Service Metadata Locator) integration for automatic DNS registration",
    "Peppol Directory integration for participant discovery",
    "Bearer token and Basic Auth authentication for REST API",
    "Content Security Policy (CSP) support and production security hardening",
    "Reverse proxy support with configurable public URL"
  ],
  "publicApiSurface": [
    "GET /{ServiceGroupId} — List document types for a participant",
    "PUT /{ServiceGroupId} — Create or update a service group",
    "DELETE /{ServiceGroupId} — Delete a service group",
    "GET /{ServiceGroupId}/services/{DocumentTypeId} — Get service endpoints",
    "PUT /{ServiceGroupId}/services/{DocumentTypeId} — Define AP endpoints",
    "DELETE /{ServiceGroupId}/services/{DocumentTypeId} — Delete service metadata",
    "GET /businesscard/{ServiceGroupId} — Get business card",
    "PUT /businesscard/{ServiceGroupId} — Create or update business card",
    "DELETE /businesscard/{ServiceGroupId} — Delete business card",
    "GET /smp-status/ — Health and status JSON endpoint"
  ]
}
